PORT=3000

# Local only — path to the downloaded Firebase private key file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Railway / production — paste the FULL service account JSON as ONE line
# (or base64-encode the file contents). Do NOT set FIREBASE_SERVICE_ACCOUNT_PATH on Railway.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n",...}
